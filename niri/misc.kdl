prefer-no-csd

screenshot-path "~/Pictures/Screenshots/Screenshot from %Y-%m-%d %H-%M-%S.png"

environment {
    QT_QPA_PLATFORM "wayland"
    // DISPLAY null
}

cursor {
    xcursor-theme "Bibata-Modern-Classic"
    xcursor-size 22

    hide-when-typing
    hide-after-inactive-ms 3000
}

overview {
    zoom 0.5
    backdrop-color "#161616"

    workspace-shadow {
        // off
        softness 40
        spread 10
        offset x=0 y=10
        color "#00000050"
    }
}

xwayland-satellite {
    // off
    path "xwayland-satellite"
}

clipboard {
    // disable-primary
}

hotkey-overlay {
    skip-at-startup
    hide-not-bound
}

// Soft background blur for layer-shell panels/popups that request it
// (e.g. your bar's popups). Off by default per-window/layer unless a
// window-rule or layer-rule turns it on — see window-rules.kdl.
blur {
    passes 4
    offset 4.0
    noise 0.02
    saturation 1.2
}




